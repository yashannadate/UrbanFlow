# Environment variables & secrets
.env
*.env

# Python bytecode & cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Virtual Environments
venv/
.venv/
env/
ENV/

# Data files (exclude CSV raw data to avoid cluttering git history)
data/raw/*.csv
data/processed/*.csv
!data/raw/.gitkeep
!data/processed/.gitkeep

# Power BI temp files
*.tmp

# OS junk files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE & Editor files
.vscode/
.idea/
*.swp
*.swo
